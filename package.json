{
  "name": "pdf-figure-picker",
  "version": "0.1.0",
  "description": "A web-based tool to open multi-page PDFs, crop a selected page, and download the cropped PDF",
  "author": "jeanhwea",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite",
    "format": "prettier --write src/**/*",
    "format:check": "prettier --check src/**/*",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  },
  "keywords": [
    "react",
    "pdf",
    "crop",
    "figure",
    "web-app"
  ]
}
